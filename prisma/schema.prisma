generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── PHASE 1: EXISTING TABLES (with data) ───

model Product {
  id             String   @id @default(cuid())
  name           String
  url            String?
  category       String
  price          Float
  commissionRate Float
  commissionVND  Float
  platform       String

  // Sales & Trending
  salesTotal     Int?
  sales7d        Int?
  salesGrowth7d  Float?
  salesGrowth30d Float?
  revenue7d      Float?
  revenue30d     Float?
  revenueTotal   Float?

  // Competition (FastMoss KOL data)
  totalKOL         Int?
  kolOrderRate     Float?
  totalVideos      Int?
  totalLivestreams Int?
  affiliateCount   Int?
  creatorCount     Int?
  topVideoViews    Int?

  // Media & Links
  imageUrl        String?
  tiktokUrl       String?
  fastmossUrl     String?
  shopFastmossUrl String?

  // Shop
  shopName      String?
  shopRating    Float?
  productStatus String?

  // Listing & History
  listingDate DateTime?
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())

  // AI Scoring
  aiScore           Float?
  aiRank            Int?
  scoreBreakdown    String?
  scoringVersion    String?
  contentSuggestion String?
  platformAdvice    String?

  // Seasonal
  seasonalTag     String?
  sellWindowStart DateTime?
  sellWindowEnd   DateTime?

  // Phase 2: Personal Layer
  personalNotes          String?
  personalRating         Int?
  personalTags           String[]
  affiliateLink          String?
  affiliateLinkStatus    String?
  affiliateLinkCreatedAt DateTime?
  shopTrustScore         Int?

  // Source
  source        String
  importBatchId String
  dataDate      DateTime
  createdAt     DateTime @default(now())

  feedbacks  Feedback[]
  snapshots  ProductSnapshot[]
  campaigns  Campaign[]

  @@unique([tiktokUrl])
  @@index([category])
  @@index([aiScore])
  @@index([dataDate])
  @@index([name, shopName])
}

model Feedback {
  id                 String   @id @default(cuid())
  productId          String
  product            Product  @relation(fields: [productId], references: [id])
  aiScoreAtSelection Float

  // Ads
  adPlatform    String?
  adImpressions Int?
  adClicks      Int?
  adCTR         Float?
  adCPC         Float?
  adConversions Int?
  adCostPerConv Float?
  adROAS        Float?
  adSpend       Float?

  // Organic
  orgPlatform     String?
  orgViews        Int?
  orgLikes        Int?
  orgComments     Int?
  orgShares       Int?
  orgWatchTimeAvg Float?
  orgLinkClicks   Int?

  // Content
  videoType     String?
  videoDuration Int?
  postDate      DateTime?
  postTime      String?

  // Sales
  salesPlatform    String?
  orders           Int?
  revenue          Float?
  commissionEarned Float?
  conversionRate   Float?

  // Overall
  overallSuccess String
  feedbackDate   DateTime @default(now())
  notes          String?

  // Future extensibility (ROADMAP)
  campaignId   String?
  campaign     Campaign? @relation(fields: [campaignId], references: [id])
  dataImportId String?
  dataImport   DataImport? @relation(fields: [dataImportId], references: [id])

  @@index([productId])
  @@index([overallSuccess])
  @@index([feedbackDate])
}

model LearningLog {
  id               String   @id @default(cuid())
  weekNumber       Int
  runDate          DateTime @default(now())
  totalDataPoints  Int
  newDataPoints    Int
  currentAccuracy  Float
  previousAccuracy Float
  weightsBefore    String
  weightsAfter     String
  patternsFound    String
  insights         String
  scoringVersion   String

  @@index([weekNumber])
}

model ProductSnapshot {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id])

  price          Float
  commissionRate Float
  sales7d        Int?
  salesTotal     Int?
  revenue7d      Float?
  revenueTotal   Float?
  totalKOL       Int?
  totalVideos    Int?
  kolOrderRate   Float?
  productStatus  String?

  snapshotDate DateTime @default(now())

  @@index([productId, snapshotDate])
  @@index([importBatchId])
}

model ImportBatch {
  id          String   @id @default(cuid())
  source      String
  fileName    String
  recordCount Int
  importDate  DateTime @default(now())

  snapshots ProductSnapshot[]
}

// ─── GENERIC DATA IMPORTS (ROADMAP: 13 source types) ───

model DataImport {
  id           String   @id @default(cuid())
  sourceType   String   // "fastmoss" | "kalodata" | "fb_ads" | "tiktok_ads" | "shopee_affiliate" | "manual" | ...
  fileName     String?
  fileUrl      String?
  recordsCount Int      @default(0)
  status       String   @default("processing") // "processing" | "completed" | "failed"
  metadata     Json?
  importedAt   DateTime?
  createdAt    DateTime @default(now())

  feedbacks Feedback[]

  @@index([sourceType])
  @@index([status])
}

// ─── PHASE 2-4: FUTURE TABLES (empty, ready for expansion) ───

model Campaign {
  id           String  @id @default(cuid())
  productId    String?
  product      Product? @relation(fields: [productId], references: [id])
  platform     String  // "tiktok" | "facebook" | "shopee" | "instagram"
  campaignType String  // "paid_ads" | "organic" | "livestream"
  contentUrl   String?
  contentType  String? // "video" | "image" | "carousel" | "livestream"

  // Metrics
  spend       Float?
  revenue     Float?
  orders      Int?
  clicks      Int?
  impressions Int?
  roas        Float?
  cpc         Float?
  ctr         Float?

  // Content metadata (Phase 2)
  hookType             String?
  videoDurationSeconds Int?
  thumbnailUrl         String?
  caption              String?
  hashtags             String[]
  postedAt             DateTime?

  // A/B test (Phase 4)
  abTestGroup String?
  abTestId    String?

  metadata  Json?
  createdAt DateTime @default(now())

  feedbacks Feedback[]

  @@index([productId])
  @@index([platform])
}

model Shop {
  id       String @id @default(cuid())
  name     String
  platform String

  // Trust metrics (ROADMAP #10)
  commissionReliability Int?    // 1-5
  supportQuality        Int?    // 1-5
  samplePolicy          String? // "sends_free" | "paid_sample" | "no_sample"
  commissionCutHistory  Json?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([platform])
}

model FinancialRecord {
  id          String   @id @default(cuid())
  type        String   // "commission_received" | "ads_spend" | "other_cost"
  amount      Float
  currency    String   @default("VND")
  source      String   // "tiktok_shop" | "shopee" | "fb_ads" | ...
  referenceId String?
  productId   String?
  campaignId  String?
  date        DateTime @db.Date
  notes       String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([date])
  @@index([source])
}

model CalendarEvent {
  id            String   @id @default(cuid())
  eventType     String   // "mega_sale" | "flash_sale" | "seasonal" | "custom"
  name          String
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  prepStartDate DateTime? @db.Date
  platforms     String[]
  notes         String?
  recurring     Boolean  @default(false)
  recurrenceRule String?
  createdAt     DateTime @default(now())

  @@index([startDate])
  @@index([eventType])
}
