generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── PHASE 1: EXISTING TABLES (with data) ───

model Product {
  id             String   @id @default(cuid())
  name           String
  url            String?
  category       String
  price          Float
  commissionRate Float
  commissionVND  Float
  platform       String

  // Sales & Trending
  salesTotal     Int?
  sales7d        Int?
  salesGrowth7d  Float?
  salesGrowth30d Float?
  revenue7d      Float?
  revenue30d     Float?
  revenueTotal   Float?

  // Competition (FastMoss KOL data)
  totalKOL         Int?
  kolOrderRate     Float?
  totalVideos      Int?
  totalLivestreams Int?
  affiliateCount   Int?
  creatorCount     Int?
  topVideoViews    Int?

  // Media & Links
  imageUrl        String?
  tiktokUrl       String?
  fastmossUrl     String?
  shopFastmossUrl String?

  // Shop
  shopName      String?
  shopRating    Float?
  productStatus String?

  // Listing & History
  listingDate DateTime?
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())

  // AI Scoring
  aiScore           Float?
  aiRank            Int?
  scoreBreakdown    String?
  scoringVersion    String?
  contentSuggestion String?
  platformAdvice    String?

  // Seasonal
  seasonalTag     String?
  sellWindowStart DateTime?
  sellWindowEnd   DateTime?

  // Phase 2: Personal Layer
  personalNotes          String?
  personalRating         Int?
  personalTags           String[]
  affiliateLink          String?
  affiliateLinkStatus    String?
  affiliateLinkCreatedAt DateTime?
  shopTrustScore         Int?

  // Source
  source        String
  importBatchId String
  dataDate      DateTime
  createdAt     DateTime @default(now())

  // Phase 2: Link to Product Identity
  identityId String? @unique
  identity   ProductIdentity? @relation(fields: [identityId], references: [id])

  feedbacks    Feedback[]
  snapshots    ProductSnapshot[]
  campaigns    Campaign[]
  contentPosts ContentPost[]

  @@unique([tiktokUrl])
  @@index([category])
  @@index([aiScore])
  @@index([dataDate])
  @@index([name, shopName])
}

model Feedback {
  id                 String   @id @default(cuid())
  productId          String
  product            Product  @relation(fields: [productId], references: [id])
  aiScoreAtSelection Float

  // Ads
  adPlatform    String?
  adImpressions Int?
  adClicks      Int?
  adCTR         Float?
  adCPC         Float?
  adConversions Int?
  adCostPerConv Float?
  adROAS        Float?
  adSpend       Float?

  // Organic
  orgPlatform     String?
  orgViews        Int?
  orgLikes        Int?
  orgComments     Int?
  orgShares       Int?
  orgWatchTimeAvg Float?
  orgLinkClicks   Int?

  // Content
  videoType     String?
  videoDuration Int?
  postDate      DateTime?
  postTime      String?

  // Sales
  salesPlatform    String?
  orders           Int?
  revenue          Float?
  commissionEarned Float?
  conversionRate   Float?

  // Overall
  overallSuccess String
  feedbackDate   DateTime @default(now())
  notes          String?

  // Future extensibility (ROADMAP)
  campaignId   String?
  campaign     Campaign? @relation(fields: [campaignId], references: [id])
  dataImportId String?
  dataImport   DataImport? @relation(fields: [dataImportId], references: [id])

  @@index([productId])
  @@index([overallSuccess])
  @@index([feedbackDate])
  @@index([campaignId])
}

model LearningLog {
  id               String   @id @default(cuid())
  weekNumber       Int
  runDate          DateTime @default(now())
  totalDataPoints  Int
  newDataPoints    Int
  currentAccuracy  Float
  previousAccuracy Float
  weightsBefore    String
  weightsAfter     String
  patternsFound    String
  insights         String
  scoringVersion   String

  @@index([weekNumber])
}

model ProductSnapshot {
  id            String      @id @default(cuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id])

  price          Float
  commissionRate Float
  sales7d        Int?
  salesTotal     Int?
  revenue7d      Float?
  revenueTotal   Float?
  totalKOL       Int?
  totalVideos    Int?
  kolOrderRate   Float?
  productStatus  String?

  snapshotDate DateTime @default(now())

  @@index([productId, snapshotDate])
  @@index([importBatchId])
}

model ImportBatch {
  id          String   @id @default(cuid())
  source      String
  fileName    String
  recordCount Int
  importDate  DateTime @default(now())

  // Background processing status
  status          String @default("pending") // "pending" | "processing" | "completed" | "failed" | "partial"
  rowsProcessed   Int    @default(0)
  rowsCreated     Int    @default(0)
  rowsUpdated     Int    @default(0)
  rowsError       Int    @default(0)
  scoringStatus   String @default("pending") // "pending" | "processing" | "completed" | "failed"
  errorLog        Json?
  completedAt     DateTime?

  snapshots ProductSnapshot[]

  @@index([status])
}

// ─── GENERIC DATA IMPORTS (ROADMAP: 13 source types) ───

model DataImport {
  id         String @id @default(cuid())
  sourceType String // "fastmoss" | "kalodata" | "fb_ads" | "tiktok_ads" | "shopee_ads" | "tiktok_affiliate" | "shopee_affiliate" | "generic" | "unknown"
  fileName   String?
  fileSize   Int?

  // Detection
  detectedType         String? // Auto-detected file type
  detectionConfidence  String? // "high" | "medium" | "low"
  userConfirmedType    String? // User override if detection wrong

  // Processing
  status       String @default("pending") // "pending" | "processing" | "completed" | "failed" | "partial"
  rowsTotal    Int    @default(0)
  rowsImported Int    @default(0)
  rowsSkipped  Int    @default(0)
  rowsError    Int    @default(0)

  // Results
  campaignsCreated       Int @default(0)
  campaignsUpdated       Int @default(0)
  productsCreated        Int @default(0)
  productsUpdated        Int @default(0)
  financialRecordsCreated Int @default(0)

  errorLog    Json?
  metadata    Json?
  importedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  feedbacks Feedback[]

  @@index([sourceType])
  @@index([status])
  @@index([createdAt])
}

// ─── PHASE 3A: CAMPAIGN TRACKER ───

model Campaign {
  id        String   @id @default(cuid())
  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  // Basic info
  name     String
  platform String  // "tiktok" | "facebook" | "shopee" | "youtube" | "google" | "organic" | "other"
  status   String  @default("planning") // "planning" | "creating_content" | "running" | "paused" | "completed" | "cancelled"

  // Planning
  plannedBudgetDaily  Int?
  plannedDurationDays Int?
  affiliateLink       String?

  // Content
  contentUrl   String?
  contentType  String? // "review" | "demo" | "unbox" | "lifestyle" | "livestream" | "other"
  contentNotes String?
  postedAt     DateTime?

  // Daily results + checklist (JSONB)
  dailyResults Json @default("[]")
  checklist    Json @default("[]")

  // Auto-calculated summary
  totalSpend   Int   @default(0)
  totalRevenue Int   @default(0)
  totalOrders  Int   @default(0)
  roas         Float?
  profitLoss   Int   @default(0)

  // Conclusion
  verdict        String? // "profitable" | "break_even" | "loss"
  lessonsLearned String?

  // Source tracking
  sourceType   String @default("manual")
  dataImportId String?

  // Timestamps
  startedAt DateTime?
  endedAt   DateTime?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedbacks        Feedback[]
  contentPosts     ContentPost[]
  financialRecords FinancialRecord[]

  @@index([productId])
  @@index([platform])
  @@index([status])
}

model ContentPost {
  id         String    @id @default(cuid())
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  productId  String?
  product    Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  url         String
  platform    String
  contentType String? // "review" | "demo" | "unbox" | "lifestyle" | "livestream"

  // Performance
  views    Int?
  likes    Int?
  comments Int?
  shares   Int?

  notes    String?
  postedAt DateTime?
  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([productId])
}

model UserGoal {
  id           String   @id @default(cuid())
  type         String   @default("monthly_profit") // "monthly_profit" | "monthly_revenue" | "campaigns_count"
  targetAmount Int
  periodStart  DateTime @db.Date
  periodEnd    DateTime @db.Date

  // Auto-calculated
  currentAmount   Int   @default(0)
  progressPercent Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([periodStart])
}

model Shop {
  id       String @id @default(cuid())
  name     String
  platform String

  // Trust metrics (ROADMAP #10)
  commissionReliability Int?    // 1-5
  supportQuality        Int?    // 1-5
  samplePolicy          String? // "sends_free" | "paid_sample" | "no_sample"
  commissionCutHistory  Json?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([platform])
}

model FinancialRecord {
  id          String    @id @default(cuid())
  type        String    // "commission_received" | "ads_spend" | "other_cost"
  amount      Float
  currency    String    @default("VND")
  source      String    // "tiktok_shop" | "shopee" | "fb_ads" | ...
  referenceId String?
  productId   String?
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  date        DateTime  @db.Date
  notes       String?
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([type])
  @@index([date])
  @@index([source])
  @@index([campaignId, type, date])
}

model CalendarEvent {
  id            String   @id @default(cuid())
  eventType     String   // "mega_sale" | "flash_sale" | "seasonal" | "custom"
  name          String
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  prepStartDate DateTime? @db.Date
  platforms     String[]
  notes         String?
  recurring     Boolean  @default(false)
  recurrenceRule String?
  createdAt     DateTime @default(now())

  @@index([startDate])
  @@index([eventType])
}

// ─── PHASE 4: AI INTELLIGENCE ───

model WinPattern {
  id          String @id @default(cuid())
  label       String
  patternType String // "winning" | "losing"
  conditions  Json   // { category, priceRange, platform, contentType }
  campaignIds Json   @default("[]")

  winRate     Float
  avgROAS     Float
  totalProfit Int
  sampleSize  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patternType])
}

model WeeklyReport {
  id         String   @id @default(cuid())
  weekStart  DateTime @db.Date
  weekEnd    DateTime @db.Date
  reportData Json
  createdAt  DateTime @default(now())

  @@index([weekStart])
}

// ─── PHASE 2: PRODUCT INTELLIGENCE ───

model ProductIdentity {
  id String @id @default(cuid())

  // Identity — canonical URL là unique, fingerprint backup
  canonicalUrl      String? @unique
  fingerprintHash   String? @unique
  productIdExternal String? // ID từ TikTok Shop URL

  // Metadata cơ bản (nullable hết — enrich lazy)
  title          String?
  shopName       String?
  category       String?
  price          Int? // VND
  commissionRate Decimal?  @db.Decimal(5, 2)
  imageUrl       String?
  description    String?

  // Inbox pipeline state
  inboxState String @default("new") // "new" | "enriched" | "scored" | "briefed" | "published" | "archived"

  // Scores (nullable — tính khi có data)
  marketScore           Decimal? @db.Decimal(5, 2)
  contentPotentialScore Decimal? @db.Decimal(5, 2)
  combinedScore         Decimal? @db.Decimal(5, 2)

  // Lifecycle & Delta
  lifecycleStage String? // "new" | "rising" | "hot" | "peak" | "declining" | "unknown"
  deltaType      String? // "NEW" | "SURGE" | "COOL" | "STABLE" | "REAPPEAR"

  // User data (ghi chú, rating — optional)
  personalNotes  String?
  personalRating Int?
  personalTags   Json @default("[]")

  // Timestamps
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  product       Product?
  urls          ProductUrl[]
  inboxItems    InboxItem[]
  briefs        ContentBrief[]
  assets        ContentAsset[]
  commissions   Commission[]
  galleryImages ProductGalleryImage[]
  contentSlots  ContentSlot[]

  @@index([inboxState])
  @@index([combinedScore(sort: Desc)])
  @@index([deltaType])
}

model ProductUrl {
  id                String          @id @default(cuid())
  productIdentityId String
  productIdentity   ProductIdentity @relation(fields: [productIdentityId], references: [id], onDelete: Cascade)

  url     String @unique
  urlType String // "tiktokshop" | "fastmoss" | "kalodata" | "manual" | "video" | "shop"

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@index([productIdentityId])
}

model InboxItem {
  id String @id @default(cuid())

  // Link gốc
  rawUrl       String
  detectedType String // "product" | "video" | "shop" | "unknown"

  // Liên kết (nullable — match sau)
  productIdentityId String?
  productIdentity   ProductIdentity? @relation(fields: [productIdentityId], references: [id])

  // Metadata extract được
  extractedTitle    String?
  extractedMetadata Json @default("{}")

  // Status
  status String @default("pending") // "pending" | "matched" | "new_product" | "duplicate" | "failed"

  createdAt DateTime @default(now())

  @@index([productIdentityId])
  @@index([status])
}

// ─── PHASE 3: CONTENT FACTORY ───

model ContentBrief {
  id                String          @id @default(cuid())
  productIdentityId String
  productIdentity   ProductIdentity @relation(fields: [productIdentityId], references: [id])

  // Channel (nullable for migration — new briefs enforce via API)
  channelId String?
  channel   TikTokChannel? @relation(fields: [channelId], references: [id])

  // Generated content
  angles  Json @default("[]") // 5 angles
  hooks   Json @default("[]") // 10 hooks
  scripts Json @default("[]") // 3 scripts (different formats)

  // Metadata
  aiModel          String? @default("claude")
  promptUsed       String?
  generationTimeMs Int?

  status String @default("generated") // "generated" | "reviewed" | "exported"

  // Character-driven content
  formatSlug String? // FormatTemplate slug used for this brief
  qcStatus   String? // "pass" | "warn"
  qcDetails  Json?   // [{check, status, message}]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets ContentAsset[]

  @@index([productIdentityId])
  @@index([channelId])
}

model ContentAsset {
  id String @id @default(cuid())

  // Identity
  assetCode String? @unique // "A-20260225-0001"

  // Relations
  productIdentityId String
  productIdentity   ProductIdentity @relation(fields: [productIdentityId], references: [id])
  briefId           String?
  brief             ContentBrief? @relation(fields: [briefId], references: [id])
  productionBatchId String?
  productionBatch   ProductionBatch? @relation(fields: [productionBatchId], references: [id])

  // Content detail
  hookText String?
  hookType String? // "result" | "price" | "compare" | "myth" | "problem" | "unbox" | "trend"
  format   String? // "review_short" | "demo" | "compare" | "unbox" | "lifestyle" | "greenscreen" | "problem_solution"
  angle    String?

  // Generated content
  scriptText  String?
  captionText String?
  hashtags    Json    @default("[]")
  ctaText     String?

  // Prompts cho Kling/Veo3
  videoPrompts Json @default("[]") // [{ scene, prompt_kling, prompt_veo3, duration_s, text_overlay }]

  // Content strategy (GĐ1)
  contentType    String? // "entertainment" | "education" | "review" | "selling"
  videoFormat    String? // "before_after" | "product_showcase" | "slideshow_voiceover" | "tutorial_steps" | "comparison" | "trending_hook"
  targetDuration Int?    // seconds
  channelId      String?
  channel        TikTokChannel? @relation(fields: [channelId], references: [id])
  hookOptions    Json?   // ["Hook 1...", "Hook 2...", "Hook 3..."]
  soundStyle     String? // "upbeat" | "calm" | "dramatic" | "trending"
  ctaSuggestion  String?

  // Compliance
  complianceStatus String? @default("unchecked") // "unchecked" | "passed" | "warning" | "blocked"
  complianceNotes  String?

  // Lifecycle
  status String @default("draft") // "draft" | "produced" | "rendered" | "published" | "logged" | "archived" | "failed"

  // Published info
  publishedUrl String?
  postId       String?
  publishedAt  DateTime?

  // Versioning
  version       Int     @default(1)
  parentAssetId String?
  parentAsset   ContentAsset?  @relation("AssetVersions", fields: [parentAssetId], references: [id])
  childAssets   ContentAsset[] @relation("AssetVersions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Phase 4: Relations
  metrics AssetMetric[]

  // Phase 5: Relations
  commissions Commission[]

  // GĐ1: Tracking
  tracking VideoTracking?

  // Calendar slots linked to this asset (1:1)
  slots ContentSlot[] @relation("SlotAsset")

  @@index([productIdentityId])
  @@index([status])
  @@index([productionBatchId])
  @@index([postId])
  @@index([channelId])
}

model ProductionBatch {
  id String @id @default(cuid())

  batchDate        DateTime @default(now()) @db.Date
  targetVideoCount Int
  actualVideoCount Int      @default(0)

  status String @default("active") // "active" | "done"
  notes  String?

  createdAt DateTime @default(now())

  assets ContentAsset[]
}

// ─── PHASE 4: RESULT + LEARNING ───

model AssetMetric {
  id             String       @id @default(cuid())
  contentAssetId String
  contentAsset   ContentAsset @relation(fields: [contentAssetId], references: [id], onDelete: Cascade)

  // Khi nào capture
  capturedAt DateTime @default(now())
  source     String   @default("manual") // "manual" | "extension" | "import"

  // Core metrics
  views    Int?
  likes    Int?
  comments Int?
  shares   Int?
  saves    Int?

  // Advanced metrics (extension/import)
  avgWatchTimeS  Decimal? @db.Decimal(5, 2)
  completionRate Decimal? @db.Decimal(3, 2)
  followersGained Int?

  // Business metrics
  clicks           Int?
  orders           Int?
  commissionAmount Int? // VND

  // Computed
  rewardScore Decimal @default(0) @db.Decimal(8, 4)

  // Raw data (import CSV/extension)
  rawData Json?

  createdAt DateTime @default(now())

  @@index([contentAssetId])
  @@index([capturedAt(sort: Desc)])
}

model LearningWeightP4 {
  id String @id @default(cuid())

  scope     String // "hook_type" | "format" | "angle" | "category" | "price_range"
  key       String // VD: "result", "review_short", "Mỹ phẩm"
  channelId String @default("") // "" = global weight (all channels), "clxxxx" = channel-specific

  weight      Decimal @default(0) @db.Decimal(10, 4)
  sampleCount Int     @default(0)
  avgReward   Decimal @default(0) @db.Decimal(8, 4)

  decayHalfLifeDays Int       @default(14)
  lastRewardAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scope, key, channelId])
  @@index([scope])
  @@index([channelId])
}

model UserPattern {
  id String @id @default(cuid())

  patternType String // "winning" | "losing"
  label       String // "Review ngắn + Mỹ phẩm < 200K"

  conditions Json // { hook_type, format, category, price_range }
  assetIds   Json @default("[]")
  sampleSize Int  @default(0)

  avgViews  Int?
  avgReward Decimal? @db.Decimal(8, 4)
  winRate   Decimal? @db.Decimal(3, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── PHASE 5: BUSINESS LAYER ───

model Commission {
  id String @id @default(cuid())

  // Links (cả hai optional)
  productIdentityId String?
  productIdentity   ProductIdentity? @relation(fields: [productIdentityId], references: [id])
  contentAssetId    String?
  contentAsset      ContentAsset? @relation(fields: [contentAssetId], references: [id])

  // Tiền
  amount   Int    // VND
  platform String? // "tiktokshop" | "shopee" | "lazada" | "other"

  // Thời gian
  earnedDate   DateTime  @db.Date
  receivedDate DateTime? @db.Date

  // Status
  status String @default("pending") // "pending" | "confirmed" | "paid" | "rejected"

  notes   String?
  rawData Json?

  createdAt DateTime @default(now())

  @@index([productIdentityId])
  @@index([contentAssetId])
  @@index([earnedDate(sort: Desc)])
  @@index([status])
}

model DailyBrief {
  id String @id @default(cuid())

  briefDate DateTime @unique @db.Date

  // Generated content (JSON)
  content Json

  aiModel     String?
  generatedAt DateTime @default(now())

  @@index([briefDate(sort: Desc)])
}

model GoalP5 {
  id String @id @default(cuid())

  periodType  String   // "weekly" | "monthly"
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date

  // Targets
  targetVideos     Int?
  targetCommission Int? // VND
  targetViews      Int?

  // Actual (auto-calculated)
  actualVideos     Int @default(0)
  actualCommission Int @default(0)
  actualViews      Int @default(0)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodType, periodStart])
}

// ─── TIKTOK STUDIO ANALYTICS ───

model AccountDailyStat {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  videoViews   Int      @default(0)
  profileViews Int      @default(0)
  likes        Int      @default(0)
  comments     Int      @default(0)
  shares       Int      @default(0)
  importBatchId String?
  createdAt    DateTime @default(now())

  @@unique([date])
  @@index([date])
}

model FollowerActivity {
  id           String   @id @default(cuid())
  dayOfWeek    Int      // 0=Mon..6=Sun
  hour         Int      // 0-23
  activeCount  Int      @default(0)
  importBatchId String?
  updatedAt    DateTime @updatedAt

  @@unique([dayOfWeek, hour])
}

model AccountInsight {
  id            String    @id @default(cuid())
  type          String    // "viewers" | "follower_history" | "follower_gender" | "follower_territories"
  date          DateTime? @db.Date
  data          Json      // flexible JSON for each insight type
  importBatchId String?
  createdAt     DateTime  @default(now())

  @@index([type])
  @@index([date])
}

// ─── SETTINGS ───

model AiModelConfig {
  id        String   @id @default(cuid())
  taskType  String   @unique // "scoring" | "content_brief" | "morning_brief" | "weekly_report"
  modelId   String   // e.g. "claude-sonnet-4-6"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiProvider {
  id           String    @id @default(cuid())
  provider     String    @unique // "anthropic" | "openai" | "google"
  encryptedKey String?   // AES-256-GCM encrypted
  isConnected  Boolean   @default(false)
  lastTestedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── GĐ1: TIKTOK CHANNEL MANAGEMENT ───

model TikTokChannel {
  id     String @id @default(cuid())
  name   String // Tên kênh
  handle String? // @handle TikTok

  niche String @default("beauty_skincare")

  // Persona
  personaName    String  // VD: "Chi Lan Beauty"
  personaDesc    String  // Mô tả persona
  voiceStyle     String  @default("casual") // "casual" | "professional" | "energetic" | "calm"
  targetAudience String? // VD: "Nữ 18-35, quan tâm skincare"

  // Style Guide
  colorPrimary  String? // Hex color
  colorSecondary String?
  fontStyle     String? // "modern" | "elegant" | "playful" | "minimal"
  editingStyle  String? // "fast_cut" | "smooth" | "cinematic" | "minimal"

  // Sub-niche & Positioning
  subNiche           String?
  usp                String?

  // Content Strategy
  contentPillars     Json?   // string[]
  hookBank           Json?   // string[]
  contentMix         Json?   // { entertainment: 40, education: 25, review: 20, selling: 15 }
  postsPerDay        Int?
  postingSchedule    Json?   // { mon: { times: ["10:00","19:00"], focus: "review" }, ... }
  seriesSchedule     Json?   // [{ name, dayOfWeek, contentPillar }]

  // AI Video Production
  contentPillarDetails Json?  // [{ pillar, aiFeasibility, recommendedFormats, productionNotes }]
  videoFormats         Json?  // [{ contentType, primaryFormat, secondaryFormat, aiToolSuggestion, productionNotes }]
  productionStyle      String? // "voiceover_broll" | "talking_head" | "product_showcase" | "hybrid"
  productionStyleReason String?

  // CTA & Competitors
  ctaTemplates       Json?   // { entertainment, education, review, selling }
  competitorChannels Json?   // [{ handle, followers, whyReference }]

  // AI Generation metadata
  generatedByAi      Boolean  @default(false)
  aiGeneratedAt      DateTime?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contentSlots    ContentSlot[]
  contentAssets   ContentAsset[]
  briefs          ContentBrief[]
  refreshLogs     TacticalRefreshLog[]
  characterBible  CharacterBible?
  formatTemplates FormatTemplate[]
  ideaMatrixItems IdeaMatrixItem[]
}

model ContentSlot {
  id        String       @id @default(cuid())
  channelId String
  channel   TikTokChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  scheduledDate DateTime @db.Date
  scheduledTime String?  // "10:00" | "19:00"

  contentType String // "entertainment" | "education" | "review" | "selling"
  videoFormat String? // "before_after" | "product_showcase" | ...

  productIdentityId String?
  productIdentity   ProductIdentity? @relation(fields: [productIdentityId], references: [id])
  contentAssetId    String?
  contentAsset      ContentAsset? @relation("SlotAsset", fields: [contentAssetId], references: [id])

  status String @default("planned") // "planned" | "briefed" | "produced" | "published" | "skipped"
  notes  String?

  createdAt DateTime @default(now())

  @@index([channelId, scheduledDate])
  @@index([scheduledDate])
  @@index([contentAssetId])
}

model VideoTracking {
  id             String       @id @default(cuid())
  contentAssetId String       @unique
  contentAsset   ContentAsset @relation(fields: [contentAssetId], references: [id], onDelete: Cascade)

  // TikTok post
  tiktokVideoUrl String?
  publishedAt    DateTime?

  // Performance metrics
  views24h Int?
  views7d  Int?
  likes    Int?
  comments Int?
  shares   Int?
  saves    Int?

  // Conversion
  clicksToShop Int?
  orders       Int?
  revenue      Float? // VND
  commission   Float? // VND

  // Winner detection
  isWinner  Boolean @default(false)
  winReason String? // "high_views" | "high_conversion" | "high_engagement"

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([isWinner])
}

// ─── TACTICAL REFRESH LOG ───

model TacticalRefreshLog {
  id        String @id @default(cuid())
  channelId String
  channel   TikTokChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  trendingContext String?
  usedTracking    Boolean @default(false)
  analysisNotes   String?

  suggestions   Json @default("[]")
  appliedFields Json @default("[]")

  createdAt DateTime @default(now())

  @@index([channelId, createdAt(sort: Desc)])
}

// ─── PRODUCT GALLERY IMAGES ───

model ProductGalleryImage {
  id                String          @id @default(cuid())
  productIdentityId String
  productIdentity   ProductIdentity @relation(fields: [productIdentityId], references: [id], onDelete: Cascade)
  filename          String
  mimeType          String          // "image/jpeg" | "image/png" | "image/webp"
  data              Bytes           // PostgreSQL bytea — binary image data
  sortOrder         Int             @default(0)
  createdAt         DateTime        @default(now())

  @@index([productIdentityId])
}

// ─── CHARACTER-DRIVEN CONTENT SYSTEM ───

model CharacterBible {
  id        String        @id @default(cuid())
  channelId String        @unique
  channel   TikTokChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  // Layer 1: Core Belief + Fear + Red Lines
  coreValues     Json?   // string[] — 3 core beliefs
  coreFear       String?
  crisisResponse String?
  redLines       Json?   // string[] — things character never does

  // Layer 2: Relationship Web
  relationships Json? // [{name, role, personality, catchphrase, dynamic}]

  // Layer 3: World Rules
  worldRules  Json? // [{rule, effect}]
  weaknesses  Json? // string[] — cute weaknesses

  // Layer 4: Origin Story
  originWound  String?
  originVow    String?
  originSymbol String?

  // Layer 5: Living Space
  livingSpaces Json? // [{name, mood, visualDesc}]

  // Layer 6: Story Arc
  storyArcs Json? // [{chapter, weeks, title, description}]

  // Layer 7: Language + Ritual
  catchphrases    Json? // string[]
  insideJokes     Json? // string[]
  rituals         Json? // string[]
  vocabularyRules Json? // string[] — words to always/never use

  // Consistency Locks
  visualLocks Json? // {props: string[], texture: string, colorPalette: string}
  voiceDna    Json? // {tone: string, pace: string, signature: string}

  // Meta
  generatedByAi   Boolean   @default(false)
  aiGeneratedAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model FormatTemplate {
  id        String        @id @default(cuid())
  channelId String
  channel   TikTokChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  name        String
  slug        String
  description String?
  goal        String? // what this format achieves

  // Structure templates
  hookTemplate  String? // template for hook section
  bodyTemplate  String? // template for body section
  proofTemplate String? // template for proof/evidence section
  ctaTemplate   String? // template for CTA section

  exampleScript String? // full example script

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([channelId, slug])
  @@index([channelId])
}

model IdeaMatrixItem {
  id        String        @id @default(cuid())
  channelId String
  channel   TikTokChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  // Cross reference
  bibleLayer  String // "core_beliefs" | "relationships" | "world_rules" | "origin" | "living_spaces" | "story_arcs" | "language"
  layerDetail String // specific element from that layer
  formatSlug  String // slug of FormatTemplate

  // Idea content
  ideaTitle       String
  hookSuggestions Json?   // string[] — 2-3 hook ideas
  angle           String?
  notes           String?

  // Status tracking
  status  String  @default("fresh") // "fresh" | "picked" | "briefed" | "dismissed"
  briefId String? // linked ContentBrief when status = "briefed"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelId, status])
  @@index([channelId, bibleLayer])
}
